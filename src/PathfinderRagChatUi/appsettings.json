{
  "Corpus": {
    "Name": "pf2e-srd",
    "RepositoryUrl": "https://github.com/Obsidian-TTRPG-Community/Pathfinder-2E-SRD-Markdown",
    "Branch": "main",
    "WorkingDirectory": "data/source",
    "UseWholeRepo": false,
    "IncludeRoots": [ "compendium", "rules", "fantasy-bestiary" ],
    "ExcludeRoots": [],
    "MarkdownGlob": "**/*.md",
    "ChunkSize": 800,
    "ChunkOverlap": 140
  },
  "Ollama": {
    "BaseUrl": "http://192.168.0.252:11434",
    "EmbeddingModel": "nomic-embed-text:latest",
    "ChatModel": "qwen2.5-coder:14b"
  },
  "Seq": {
    "ServerUrl": "https://seq.polyhydragames.com",
    "MinimumLevel": "Information"
  },
  "Database": {
    "Path": "data/app.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
